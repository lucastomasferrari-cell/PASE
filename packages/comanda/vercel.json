{
  "outputDirectory": "dist",
  "ignoreCommand": "exit 1",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pase-yndx.vercel.app/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://pase-yndx.vercel.app/api/sitemap"
    },
    {
      "source": "/((?!api/|sitemap\\.xml$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
