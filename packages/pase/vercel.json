{
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "redirects": [
    {
      "source": "/comanda-app",
      "destination": "https://pase-comanda.vercel.app/",
      "permanent": true
    },
    {
      "source": "/comanda-app/",
      "destination": "https://pase-comanda.vercel.app/",
      "permanent": true
    },
    {
      "source": "/comanda-app/:path*",
      "destination": "https://pase-comanda.vercel.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/((?!api/|sitemap\\.xml$).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/mp-sync.js": {
      "maxDuration": 300
    },
    "api/mp-generate.js": {
      "maxDuration": 30
    },
    "api/mp-process.js": {
      "maxDuration": 60
    },
    "api/backup-tenants.js": {
      "maxDuration": 300
    },
    "api/mp-update-pending-releases.js": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
