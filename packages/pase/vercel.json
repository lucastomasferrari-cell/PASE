{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/mp-sync.js": {
      "maxDuration": 300
    },
    "api/mp-generate.js": {
      "maxDuration": 30
    },
    "api/mp-process.js": {
      "maxDuration": 60
    },
    "api/backup-tenants.js": {
      "maxDuration": 300
    },
    "api/backup-cleanup.js": {
      "maxDuration": 60
    },
    "api/mp-update-pending-releases.js": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
