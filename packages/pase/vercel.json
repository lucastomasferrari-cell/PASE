{
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/mp-sync",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/mp-sync.js": {
      "maxDuration": 300
    },
    "api/mp-generate.js": {
      "maxDuration": 30
    },
    "api/mp-process.js": {
      "maxDuration": 60
    },
    "api/mp-debug-balance.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
