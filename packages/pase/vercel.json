{
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/mp-sync",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/mp-sync.js": {
      "maxDuration": 300
    },
    "api/mp-generate.js": {
      "maxDuration": 30
    },
    "api/mp-process.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
