{
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/mp-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/backup-tenants",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/backup-cleanup",
      "schedule": "0 5 * * 0"
    }
  ],
  "functions": {
    "api/mp-sync.js": {
      "maxDuration": 300
    },
    "api/mp-generate.js": {
      "maxDuration": 30
    },
    "api/mp-process.js": {
      "maxDuration": 60
    },
    "api/backup-tenants.js": {
      "maxDuration": 300
    },
    "api/backup-cleanup.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
