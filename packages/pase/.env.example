# Supabase anon key (público, pero NO hardcodeada para permitir rotación).
# Copiar este archivo a .env.local y pegar el valor real (nunca commitearlo).
# En producción: configurar en Vercel → Project Settings → Environment Variables.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Server-side (api/), configurar SOLO en Vercel ──────────────────────────
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role_key>
#
# Telegram webhook (api/telegram-webhook.js):
# TELEGRAM_BOT_TOKEN=<bot-token>
# TELEGRAM_CHAT_USERS="chatIdA:userIdA,chatIdB:userIdB"
#   - chatId: id numérico de Telegram (string).
#   - userId: usuarios.id (INTEGER) en PASE.
#   - El bot resuelve chat_id → user_id desde acá y deriva tenant_id desde
#     usuarios. Sin entrada en este map → 403.
#   - Ejemplo: TELEGRAM_CHAT_USERS="6543210987:12,1234567890:7"
