{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "ignoreCommand": "npx -y turbo-ignore @pase/instagram-bot",
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/send.js": {
      "maxDuration": 15
    },
    "api/oauth-callback.js": {
      "maxDuration": 15
    },
    "api/refresh-tokens.js": {
      "maxDuration": 60
    },
    "api/diagnostic.js": {
      "maxDuration": 10
    },
    "api/auth-bridge.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
