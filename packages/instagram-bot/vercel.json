{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "echo 'no build step — solo serverless functions en api/'",
  "outputDirectory": "public",
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/send.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
