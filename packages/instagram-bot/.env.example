# ─── Frontend (Vite — se inyecta en BUILD-TIME, requiere redeploy al cambiar) ───
# Anon key PÚBLICA de Supabase. Es la MISMA del resto del ecosistema
# (copiala del proyecto pase-yndx / PASE). La Supabase URL va hardcodeada en
# src/lib/supabase.ts (convención del repo), así que esta es la única var del
# frontend que hace falta.
VITE_SUPABASE_ANON_KEY=

# Opcional: override del origin del backend del bot. Por default es same-origin
# (la web vive en el mismo deploy que /api/send), así que dejalo vacío.
# VITE_IG_BOT_URL=

# ─── Backend (Vercel Functions de api/ — RUNTIME, no son del frontend) ──────────
# Ya están configuradas en el proyecto Vercel. NO llevan prefijo VITE_:
#   SUPABASE_URL, SUPABASE_SERVICE_KEY, ANTHROPIC_API_KEY,
#   META_VERIFY_TOKEN, META_APP_SECRET, (web-push) VAPID_*, etc.
